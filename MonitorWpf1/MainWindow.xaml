<Window x:Class="MonitorWpf1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MonitorWpf1"
        mc:Ignorable="d"
		WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        Title="Monitor"
		Topmost="False"
		Background="Black"
		>
	<Grid>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="400"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="1" BorderBrush="DarkGray" BorderThickness="1" Margin="5" Padding="8" CornerRadius="12"  Background="SlateGray">

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<!-- Last updated -->
					<RowDefinition Height="*"/>
					<!-- Dynamic news -->
					<RowDefinition Height="Auto"/>
					<!-- System time -->
				</Grid.RowDefinitions>

				<!-- Top: Last updated -->
				<TextBlock x:Name="LastUpdatedText" Grid.Row="0" Text="nothing fetched" FontWeight="Bold" 
						   FontSize="14" TextAlignment="Center" Margin="0,0,0,10" />

				<!-- Middle: Dynamic news items -->
				<ScrollViewer x:Name="NewsScrollViewer" Grid.Row="1" FlowDirection="RightToLeft"
				  VerticalScrollBarVisibility="Visible"
				  HorizontalScrollBarVisibility="Disabled">
					<ScrollViewer.Resources>
						<Style TargetType="ScrollBar">
							<Setter Property="Background" Value="DarkGray"/>
							<Setter Property="Foreground" Value="LightBlue"/>
							<Setter Property="Width" Value="12"/>
						</Style>
					</ScrollViewer.Resources>
					<ItemsControl x:Name="NewsItemsControl">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<StackPanel Margin="0,5">
									<TextBlock>
										<Run Text="{Binding date, StringFormat={}{0:dd/MM HH:mm}}" FontSize="14" />
									</TextBlock>
									<TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{Binding title}" FontSize="18" />
									<TextBlock TextWrapping="Wrap" Text="{Binding text}" FontSize="16" />
									<Separator Margin="0,8,0,8"/>
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
				

				<!-- Bottom: System time -->
				<TextBlock x:Name="SystemTimeText" Grid.Row="2" Text="00:00:00" FontSize="24"
                   HorizontalAlignment="Center" FontStyle="Italic"/>
			</Grid>
		</Border>

		<Grid Grid.Column="0">
			<Grid.RowDefinitions>
				<RowDefinition Height="3*"/>
				<RowDefinition Height="1*"/>
			</Grid.RowDefinitions>
			
			

			<Border Grid.Row="0" BorderBrush="Black" BorderThickness="1" Margin="5" Background="Gray" CornerRadius="12" FlowDirection="RightToLeft" >
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<StackPanel Grid.Row="0">
						<ItemsControl x:Name="AlertsControl">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>

							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Padding="10" Margin="5" CornerRadius="5" BorderThickness="1" BorderBrush="Black" Background="{Binding GroupColor}" MaxWidth="500">
										<StackPanel>
											<TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18"/>
											<TextBlock Text="{Binding AlertDate, StringFormat='dd/MM HH:mm'}"/>
											<TextBlock Text="{Binding LocationsText}" FontSize="15" TextWrapping="Wrap" />
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<TextBlock x:Name="LabelNoData" Text="No Data" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
					</StackPanel>
					

					<!-- Last updated -->
					<TextBlock x:Name="AlertsLastUpdatedText"  Grid.Row="1"
					   Text="Last updated: --"
					   FontSize="14"
					   FontWeight="Bold"
						FontStyle="Italic"
					   Margin="5"
					   HorizontalAlignment="Center"/>
				</Grid>
			</Border>

			<Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Margin="5" Background="DimGray" CornerRadius="12">
				<TextBlock Text="CONTENT BOTTOM" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
			</Border>
		</Grid>


	</Grid>
</Window>
