<UserControl x:Class="MonitorWpf1.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Background="SlateGray">
	<Border Padding="1">
		<Grid x:Name="MapContainer">
			<Image x:Name="MapImage" 
                   Source="/Resources/mapsisrael.jpg" 
                   Stretch="Uniform"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
				   MouseDown="MapImage_MouseDown"
				   />

			<Canvas x:Name="OverlayCanvas" 
                    IsHitTestVisible="False"
                    Width="{Binding ElementName=MapImage, Path=ActualWidth}"
                    Height="{Binding ElementName=MapImage, Path=ActualHeight}"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"/>
		</Grid>
	</Border>
</UserControl>